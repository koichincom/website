---
import { formatDate } from "../utils/date-formatter";
import ProseLayout from "./ProseLayout.astro";
import type { TocHeading } from "../utils/table-of-contents";
import NewWindowLink from "../components/NewWindowLink.astro";

export interface Props {
    title: string;
    published: Date;
    lastUpdated?: Date;
    readingTime: string;
    description?: string;
    headings?: TocHeading[];
}
const { title, published, lastUpdated, readingTime, description, headings } =
    Astro.props;
---

<ProseLayout title={title} description={description} headings={headings}>
    <p
        class="not-prose mb-4 text-base text-(--color-text-third) dark:text-(--color-text-third-dark) flex items-center gap-2"
    >
        {
            readingTime && (
                <>
                    <span>{readingTime}</span>
                    <span aria-hidden="true">·</span>
                </>
            )
        }
        <time datetime={published.toISOString()}>{formatDate(published)}</time>
        {
            lastUpdated && (
                <>
                    <span aria-hidden="true">·</span>
                    <span>Last updated:</span>
                    <time datetime={lastUpdated.toISOString()}>
                        {formatDate(lastUpdated)}
                    </time>
                </>
            )
        }
    </p>
    <article>
        <slot />
    </article>
    <div slot="cta" class="mt-10 px-content-inset text-base leading-relaxed">
        <div
            class="mb-10 border-t border-(--color-divider) dark:border-(--color-divider-dark)"
            aria-hidden="true"
        >
        </div>
        <p>
            If you found this article interesting, consider sharing it with your
            friends, or following me by <a href="/feed">Atom feed</a> or on
            <NewWindowLink href="https://x.com/koichincom"
                >X (Twitter)</NewWindowLink
            >.
        </p>
    </div>
</ProseLayout>
