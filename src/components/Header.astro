---
import { classNames } from "../utils/class-names";
import Logo from "./Logo.astro";
import {
    getActiveSection,
    getExactActiveSection,
    normalizePath,
    type TopLevelPath,
} from "../utils/nav-section";

interface NavItem {
    path: TopLevelPath;
    href: string;
    label: string;
}

const navItems: NavItem[] = [
    { path: "writing", href: "/writing", label: "Writing" },
    { path: "project", href: "/project", label: "Projects" },
    { path: "about", href: "/about", label: "About" },
];

const normalizedPath = normalizePath(Astro.url.pathname);
const activeExactSection = getExactActiveSection(normalizedPath);
const activeSection = getActiveSection(normalizedPath);

const NAV_ITEM_HITBOX_BASE =
    "nav-item group inline-flex items-center";
const NAV_ITEM_PILL_BASE =
    "nav-pill inline-flex items-center rounded-full px-surface-inset py-1";
const NAV_ITEM_HOME_PILL_GAP = "gap-2 sm:gap-3";
const NAV_ITEM_PILL_HOVER_BG =
    "group-hover:bg-(--color-hover) group-focus-visible:bg-(--color-hover) dark:group-hover:bg-(--color-hover-dark) dark:group-focus-visible:bg-(--color-hover-dark)";
const NAV_ITEM_PILL_HOVER_TEXT =
    "group-hover:text-(--color-accent-light) group-focus-visible:text-(--color-accent-light) dark:group-hover:text-(--color-accent-dark) dark:group-focus-visible:text-(--color-accent-dark)";
const NAV_ITEM_PILL_ACTIVE_VARIANTS =
    "group-data-[active=section]:bg-(--color-hover) dark:group-data-[active=section]:bg-(--color-hover-dark)";
const NAV_ITEM_PILL_PENDING_VARIANTS =
    "group-data-[pending=true]:bg-(--color-hover) dark:group-data-[pending=true]:bg-(--color-hover-dark)";
const NAV_CONTAINER_HAS_ACTIVE_SUPPRESS =
    "[&:has(.nav-home:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:bg-transparent dark:[&:has(.nav-home:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:bg-transparent [&:has(.nav-right:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:bg-transparent dark:[&:has(.nav-right:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:bg-transparent [&:has(.nav-home:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:bg-transparent dark:[&:has(.nav-home:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:bg-transparent [&:has(.nav-right:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:bg-transparent dark:[&:has(.nav-right:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:bg-transparent";
const NAV_CONTAINER_HAS_ACTIVE_TEXT_SUPPRESS =
    "[&:has(.nav-home:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:!text-(--color-text-second) dark:[&:has(.nav-home:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:!text-(--color-text-second-dark) [&:has(.nav-right:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:!text-(--color-text-second) dark:[&:has(.nav-right:hover)_.nav-item[data-active]:not(:hover)_>.nav-pill]:!text-(--color-text-second-dark) [&:has(.nav-home:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:!text-(--color-text-second) dark:[&:has(.nav-home:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:!text-(--color-text-second-dark) [&:has(.nav-right:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:!text-(--color-text-second) dark:[&:has(.nav-right:focus-within)_.nav-item[data-active]:not(:focus-within)_>.nav-pill]:!text-(--color-text-second-dark)";
const NAV_CONTAINER_PENDING_SUPPRESS =
    "[&[data-nav-pending='true']_.nav-item[data-active]:not(:hover):not(:focus-within)_>.nav-pill]:bg-transparent dark:[&[data-nav-pending='true']_.nav-item[data-active]:not(:hover):not(:focus-within)_>.nav-pill]:bg-transparent";
const NAV_CONTAINER_PENDING_TEXT_SUPPRESS =
    "[&[data-nav-pending='true']_.nav-item[data-active]:not(:hover):not(:focus-within)_>.nav-pill]:!text-(--color-text-second) dark:[&[data-nav-pending='true']_.nav-item[data-active]:not(:hover):not(:focus-within)_>.nav-pill]:!text-(--color-text-second-dark)";
const navClass = classNames(
    "h-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between text-base text-(--color-text-second) dark:text-(--color-text-second-dark) whitespace-nowrap",
    NAV_CONTAINER_HAS_ACTIVE_SUPPRESS,
    NAV_CONTAINER_HAS_ACTIVE_TEXT_SUPPRESS,
    NAV_CONTAINER_PENDING_SUPPRESS,
    NAV_CONTAINER_PENDING_TEXT_SUPPRESS,
);
const homeLinkClass = classNames(NAV_ITEM_HITBOX_BASE);
const homeInteractivePillClass = classNames(
    NAV_ITEM_PILL_BASE,
    NAV_ITEM_HOME_PILL_GAP,
    NAV_ITEM_PILL_HOVER_BG,
    NAV_ITEM_PILL_HOVER_TEXT,
    NAV_ITEM_PILL_ACTIVE_VARIANTS,
    NAV_ITEM_PILL_PENDING_VARIANTS,
);
const homeCurrentPillClass = classNames(
    NAV_ITEM_PILL_BASE,
    NAV_ITEM_HOME_PILL_GAP,
    NAV_ITEM_PILL_ACTIVE_VARIANTS,
);
const navItemLinkClass = classNames(NAV_ITEM_HITBOX_BASE);
const navItemInteractivePillClass = classNames(
    NAV_ITEM_PILL_BASE,
    NAV_ITEM_PILL_HOVER_BG,
    NAV_ITEM_PILL_HOVER_TEXT,
    NAV_ITEM_PILL_ACTIVE_VARIANTS,
    NAV_ITEM_PILL_PENDING_VARIANTS,
);
const navItemCurrentPillClass = classNames(
    NAV_ITEM_PILL_BASE,
    NAV_ITEM_PILL_ACTIVE_VARIANTS,
);
---

<header
    data-site-header
    class="sticky top-0 z-50 h-[var(--site-header-height)] bg-(--color-background) dark:bg-(--color-background-dark)"
>
    <nav class={navClass} data-site-nav aria-label="Primary navigation">
        <div class="flex nav-home">
            {
                activeExactSection === "home" ? (
                    <span
                        class={homeLinkClass}
                        data-section="home"
                        data-href="/"
                        data-active="section"
                        aria-current="page"
                    >
                        <span class={homeCurrentPillClass}>
                            <Logo class="h-4 w-auto" />
                            <span class="text-base sm:text-lg">
                                Koichi Nakayamada
                            </span>
                        </span>
                    </span>
                ) : (
                    <a
                        href="/"
                        class={homeLinkClass}
                        data-section="home"
                        data-href="/"
                    >
                        <span class={homeInteractivePillClass}>
                            <Logo class="h-4 w-auto" />
                            <span class="text-base sm:text-lg">
                                Koichi Nakayamada
                            </span>
                        </span>
                    </a>
                )
            }
        </div>

        <div class="flex gap-2 sm:gap-3 nav-right">
            {
                navItems.map((item) =>
                    activeSection === item.path ? (
                        activeExactSection === item.path ? (
                            <span
                                class={navItemLinkClass}
                                data-section={item.path}
                                data-href={item.href}
                                data-active="section"
                                aria-current="page"
                            >
                                <span class={navItemCurrentPillClass}>
                                    {item.label}
                                </span>
                            </span>
                        ) : (
                            <a
                                href={item.href}
                                class={navItemLinkClass}
                                data-section={item.path}
                                data-href={item.href}
                                data-active="section"
                            >
                                <span class={navItemInteractivePillClass}>
                                    {item.label}
                                </span>
                            </a>
                        )
                    ) : (
                        <a
                            href={item.href}
                            class={navItemLinkClass}
                            data-section={item.path}
                            data-href={item.href}
                        >
                            <span class={navItemInteractivePillClass}>
                                {item.label}
                            </span>
                        </a>
                    ),
                )
            }
        </div>
    </nav>
</header>
