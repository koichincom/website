---
import ListRow from "./ListRow.astro";
import type { CollectionEntry } from "astro:content";
import { cssVarStyle, normalizeMinLines } from "../utils/min-lines";
import { classNames } from "../utils/class-names";

export interface Props {
    projects: CollectionEntry<"projects">[];
    rowMinLines: number;
}

const { projects, rowMinLines } = Astro.props;

const minLines = normalizeMinLines(rowMinLines);
const rowMinHeightClass = "sm:min-h-[calc(var(--project-row-min-lines)*1lh)]";
const nameColumnClass = classNames(
    "min-w-0 sm:flex sm:items-center",
    rowMinHeightClass,
);
const descriptionColumnClass = classNames(
    "min-w-0 sm:flex sm:items-center mt-2 sm:mt-0",
    rowMinHeightClass,
);
---

<ul
    class="sm:grid sm:w-full sm:gap-x-36 sm:grid-cols-[fit-content(40%)_minmax(0,1fr)]"
>
    {
        projects.map((project) => (
            <ListRow
                href={project.data.url}
                target="_blank"
                rel="noopener noreferrer"
                ariaLabel={`Open ${project.data.name}`}
                rowClass="sm:col-span-full sm:grid sm:grid-cols-[subgrid]"
                class="no-custom-underline sm:grid sm:grid-cols-[subgrid] sm:col-span-full sm:items-start"
            >
                <div
                    class={nameColumnClass}
                    style={cssVarStyle("--project-row-min-lines", minLines)}
                >
                    <span class="text-base font-semibold text-(--color-text-second) dark:text-(--color-text-second-dark) group-hover:text-(--color-accent-light) group-focus-within:text-(--color-accent-light) dark:group-hover:text-(--color-accent-dark) dark:group-focus-within:text-(--color-accent-dark) min-w-0 break-words">
                        {project.data.name}
                    </span>
                </div>
                <div
                    class={descriptionColumnClass}
                    style={cssVarStyle("--project-row-min-lines", minLines)}
                >
                    <span class="text-base text-(--color-text-third) dark:text-(--color-text-third-dark) min-w-0 break-words">
                        {project.data.description}
                    </span>
                </div>
            </ListRow>
        ))
    }
</ul>
