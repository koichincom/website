---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

import PageTitle from "../components/PageTitle.astro";
import SectionTitle from "../components/SectionTitle.astro";
import WritingList from "../components/WritingList.astro";
import ProjectList from "../components/ProjectList.astro";
import NewWindowLink from "../components/NewWindowLink.astro";
import Button from "../components/Button.astro";

const title = "Koichi Nakayamada";
const h1Title = "Build Things, Analyze Data";

// Fetch projects sorted by pinned and published date, take featured ones
const projects = (await getCollection("projects"))
    .filter((project) => project.data.featured)
    .sort((a, b) => {
        const pinnedDelta =
            Number(b.data.pinned ?? false) - Number(a.data.pinned ?? false);
        if (pinnedDelta !== 0) return pinnedDelta;
        return (
            new Date(b.data.published).getTime() -
            new Date(a.data.published).getTime()
        );
    });

const writingPosts = (await getCollection("writing"))
    .sort(
        (a, b) =>
            new Date(b.data.published).getTime() -
            new Date(a.data.published).getTime(),
    )
    .slice(0, 3);
---

<BaseLayout metaTitle={title}>
    <PageTitle inset={false} class="text-center">{h1Title}</PageTitle>
    <div class="flex flex-col gap-8 sm:gap-12 pb-4">
        <section>
            <p
                class="px-content-inset text-center text-(--color-text-second) dark:text-(--color-text-second-dark) leading-relaxed"
            >
                Japanese developer and Data Science student in the U.S.<br
                />Interested in Open Source, CLI/TUI, AI, Data Science, Zig
                language.<br />Currently working on <NewWindowLink
                    href="https://github.com/koichincom/count.nvim"
                    >count.nvim</NewWindowLink
                >, a Neovim plugin for counting text metrics.<br />
            </p>
        </section>

        <section>
            <video controls preload="none" playsinline>
                <source src="/test.mp4" type="video/mp4" />
            </video>
        </section>

        <section>
            <span class="flex items-center justify-between mb-8">
                <SectionTitle>Featured Projects</SectionTitle>
                <a
                    href="/projects"
                    class="text-(--color-text-second) dark:text-(--color-text-second-dark)"
                    >All projects</a
                >
            </span>
            <ProjectList projects={projects} rowMinLines={2} />
        </section>

        <section>
            <span class="flex items-center justify-between mb-8">
                <SectionTitle>Latest Writing</SectionTitle>
                <a
                    href="/writing"
                    class="text-(--color-text-second) dark:text-(--color-text-second-dark)"
                    >All writing</a
                >
            </span>
            <WritingList posts={writingPosts} rowMinLines={2} />
        </section>
    </div>

    <script>
        import { AGE } from "../scripts/age-calculator";
        const ageDisplay = document.getElementById("age-display");
        if (ageDisplay) {
            ageDisplay.textContent = AGE.toString();
        }
    </script>
</BaseLayout>
