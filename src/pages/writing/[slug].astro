---
import { getCollection, render } from "astro:content";
import { getReadingTimeStr } from "../../utils/reading-time";
import { getLastUpdatedFromUpdates } from "../../utils/last-updated";
import { formatDate } from "../../utils/date-formatter";
import WritingLayout from "../../layouts/WritingLayout.astro";
import NewWindow from "../../components/NewWindowLink.astro";
import CopyStr from "../../components/CopyStr.astro";

export async function getStaticPaths() {
    const posts = await getCollection("writing");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTimeStr(post.body || "");
const lastUpdated = getLastUpdatedFromUpdates(post.data.updates);
---

<WritingLayout
    title={post.data.title}
    subtitle={post.data.subtitle}
    headings={headings}
>
    <!-- Expose NewWindowLink and CopyStr components to MDX via the MDX `components` map (works for custom tags too). -->
    <!-- https://mdxjs.com/docs/using-mdx/#how-mdx-works -->
    <Content components={{ NewWindow, CopyStr }} />

    <section slot="meta">
        <p>
            {readingTime} to read
            <time datetime={post.data.published.toISOString()}>
                · Published on {formatDate(post.data.published)}</time
            >
            {
                lastUpdated && (
                    <>
                        {" "}
                        ·{" "}
                        <time datetime={lastUpdated.toISOString()}>
                            Last updated on {formatDate(lastUpdated)}
                        </time>
                    </>
                )
            }
        </p>
    </section>
    <section slot="sidebar-meta">
        {readingTime} to read
        <br />
        <time datetime={post.data.published.toISOString()}>
            Published on <br />{formatDate(post.data.published)}</time
        >
        <br />
        {
            lastUpdated && (
                <>
                    <time datetime={lastUpdated.toISOString()}>
                        Last updated <br />
                        {formatDate(lastUpdated)}
                    </time>
                </>
            )
        }
    </section>
</WritingLayout>
