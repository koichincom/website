---
import { classNames } from "../utils/class-names";

export interface Props {
    inset?: boolean;
    class?: string;
}

const { inset = true, class: className = "" } = Astro.props;
const titleClass = classNames(
    inset && "px-content-inset",
    "text-2xl sm:text-5xl font-bold mb-8",
    className,
);
---

<h1 class={titleClass}>
    <slot />
</h1>
