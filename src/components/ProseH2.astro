---
import CopyStr from "./CopyStr.astro";

type Props = astroHTML.JSX.HTMLAttributes;

const { id, class: className, ...rest } = Astro.props as Props;
const headingBaseUrl = Astro.site
    ? new URL(Astro.url.pathname, Astro.site)
    : Astro.url;
const copyValue = id
    ? `${headingBaseUrl.toString()}#${id}`
    : headingBaseUrl.toString();
const headingCopyClass =
    "group site-copy-link-prose-heading focus-visible:text-(--color-accent-light) dark:focus-visible:text-(--color-accent-dark)";
const headingTrailingIconWrapperClass =
    "ml-[0.2em] inline-block leading-none align-baseline text-(--color-text-third) dark:text-(--color-text-third-dark) group-hover:text-(--color-accent-light) dark:group-hover:text-(--color-accent-dark) group-focus-visible:text-(--color-accent-light) dark:group-focus-visible:text-(--color-accent-dark)";
const headingIconClass = "w-[1lh] h-[1lh]";
---

<h2 id={id} class={className} {...rest}>
    <!-- prettier-ignore -->
    <CopyStr
        copyValue={copyValue}
        ariaLabel="Copy heading link"
        class={headingCopyClass}
        trailingIconWrapperClass={headingTrailingIconWrapperClass}
        iconClass={headingIconClass}
    ><!--
    --><slot /><!--
    --></CopyStr>
</h2>
