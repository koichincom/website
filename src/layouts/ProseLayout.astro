---
import BaseLayout from "./BaseLayout.astro";
import PageTitle from "../components/PageTitle.astro";
import { getH2Headings } from "../utils/table-of-contents";
import type { TocHeading } from "../utils/table-of-contents";

export interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    headings?: TocHeading[];
    fediverseCreator?: string;
}

const { title, subtitle, description, headings = [], fediverseCreator } = Astro.props;

const tocHeadings = getH2Headings(headings);
const hasToc = tocHeadings.length > 0;
const hasSidebarMetaOrToc = hasToc || Astro.slots.has("sidebar-meta");

const proseBase = "prose prose-base max-w-none ps-content-inset pe-content-inset prose-a:no-underline";
const proseScrollOffset = "[&_h2]:scroll-mt-[var(--layout-main-start-offset)] [&_h3]:scroll-mt-[var(--layout-main-start-offset)] [&_h4]:scroll-mt-[var(--layout-main-start-offset)]";
const proseLight = [
    "prose-headings:text-(--color-text-first) prose-headings:font-bold prose-p:text-(--color-text-second) prose-a:text-(--color-text-second) prose-strong:text-(--color-text-first) prose-strong:font-bold prose-blockquote:text-(--color-text-second) prose-blockquote:border-l-(--color-divider) prose-a:hover:text-(--color-accent-light) prose-a:focus-visible:text-(--color-accent-light)",
    "prose-li:text-(--color-text-second) [&_li::marker]:text-(--color-text-second)",
    "prose-th:text-(--color-text-first) prose-td:text-(--color-text-second) prose-th:border-(--color-divider) prose-td:border-(--color-divider)",
];
const proseDark = [
    "dark:prose-headings:text-(--color-text-first-dark) dark:prose-p:text-(--color-text-second-dark) dark:prose-strong:text-(--color-text-first-dark) dark:prose-a:text-(--color-text-second-dark) dark:[&_:not(pre)>code]:text-(--color-text-first-dark) dark:[&_:not(pre)>code]:bg-(--color-hover-dark) dark:[&_pre:not(.astro-code)]:bg-(--color-hover-dark) dark:prose-blockquote:text-(--color-text-second-dark) dark:prose-blockquote:border-l-(--color-divider-dark) dark:prose-a:hover:text-(--color-accent-dark) dark:prose-a:focus-visible:text-(--color-accent-dark)",
    "dark:prose-li:text-(--color-text-second-dark) dark:[&_li::marker]:text-(--color-text-second-dark)",
    "dark:prose-th:text-(--color-text-first-dark) dark:prose-td:text-(--color-text-second-dark) dark:prose-th:border-(--color-divider-dark) dark:prose-td:border-(--color-divider-dark)",
];
const proseCode = [
    "[&_:not(pre)>code]:text-(--color-text-first) [&_:not(pre)>code]:font-normal [&_:not(pre)>code]:bg-(--color-hover) [&_:not(pre)>code]:px-1 [&_:not(pre)>code]:rounded [&_code::before]:content-none [&_code::after]:content-none",
    "[&_pre:not(.astro-code)]:bg-(--color-hover)",
    "[&_pre.astro-code]:rounded-none",
];
const proseClasses = [proseBase, proseScrollOffset, ...proseLight, ...proseDark, ...proseCode];
---

<BaseLayout
    metaTitle={title}
    description={description}
    fediverseCreator={fediverseCreator}
>
    <div
        data-prose-layout
        class:list={[
            "min-w-0",
            hasSidebarMetaOrToc &&
                "lg:grid lg:grid-cols-[minmax(0,1fr)_16rem] lg:gap-10",
        ]}
    >
        <div class="min-w-0">
            <div class="mx-auto w-full max-w-[66ch]">
                <div data-prose-title>
                    <span
                        data-prose-title-sentinel
                        aria-hidden="true"
                        class="block h-px -mb-px"
                    ></span>
                    <PageTitle
                        inset={false}
                        class="ps-content-inset pe-content-inset">{title}</PageTitle
                    >
                    {subtitle && (
                        <p class="not-prose -mt-6 mb-4 px-content-inset text-base text-(--color-text-third) dark:text-(--color-text-third-dark)">
                            {subtitle}
                        </p>
                    )}
                </div>
                <div
                    class:list={proseClasses}
                >
                    <slot />
                </div>
                <slot name="cta" />
            </div>
        </div>
        {
            hasSidebarMetaOrToc && (
                <aside class="hidden lg:block self-start lg:sticky lg:top-[var(--layout-main-start-offset)] lg:max-h-[calc(100dvh-var(--layout-main-start-offset)-var(--spacing-content-inset))] lg:overflow-y-auto lg:overscroll-contain">
                    <div data-sidebar-title class="pb-4">
                        <p class="font-bold">{title}</p>
                        {subtitle && (
                            <p class="text-sm text-(--color-text-third) dark:text-(--color-text-third-dark)">{subtitle}</p>
                        )}
                    </div>
                    <div data-sidebar-body>
                        <slot name="sidebar-meta" />
                        {hasToc && (
                            <nav aria-label="Table of contents">
                                <ol class="space-y-2">
                                    {tocHeadings.map((heading) => (
                                        <li>
                                            <a
                                                href={`#${heading.slug}`}
                                                class="text-base text-(--color-text-second) dark:text-(--color-text-second-dark)"
                                            >
                                                {heading.text}
                                            </a>
                                        </li>
                                    ))}
                                </ol>
                            </nav>
                        )}
                    </div>
                </aside>
            )
        }
    </div>
</BaseLayout>
