---
export interface Props {
    class?: string;
    contentClass?: string;
}

const {
    class: className = "ml-[0.2em] inline-block leading-none align-baseline",
    contentClass = "",
} = Astro.props;
---

<!-- prettier-ignore -->
<span class={contentClass}><slot /><!--
--><span class="whitespace-nowrap" aria-hidden="true">&#8288;<span class={className}><slot name="icon" /></span></span></span>
